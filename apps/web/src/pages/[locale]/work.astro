---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getProjects } from '../../lib/cms';
import { LOCALES, getDict, isLocale, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);

const projects = await getProjects();

const pillarLabels: Record<string, string> = {
  design: t.contact.projectTypes.design,
  dev: t.contact.projectTypes.development,
  infra: t.contact.projectTypes.infrastructure,
  support: t.contact.projectTypes.support,
  consulting: t.contact.projectTypes.consulting,
};

const industries = Array.from(new Set(projects.map((p) => p.industry))).sort();
const pillars = Array.from(new Set(projects.flatMap((p) => p.services)))
  .filter((s) => pillarLabels[s])
  .sort();
---

<BaseLayout locale={locale} title={t.workIndex.title} description={t.workIndex.description}>
  <Header slot="header" locale={locale} />

  <section class="bg-paper">
    <div class="container py-16 md:py-20 lg:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">{t.workIndex.eyebrow}</p>
      <h1 class="mt-3 max-w-3xl font-display text-h1 font-bold leading-tight">
        <span class="heading-gradient">{t.workIndex.headlineEmph}</span>
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/75 md:text-xl">{t.workIndex.intro}</p>
    </div>
  </section>

  <section class="bg-mist py-12 md:py-16">
    <div class="container">
      <div
        class="flex flex-col gap-6 rounded-2xl border border-line bg-paper p-5 md:flex-row md:items-center md:justify-between md:p-6"
      >
        <div class="space-y-4 md:space-y-0 md:flex md:items-center md:gap-6">
          <fieldset>
            <legend class="font-mono text-[11px] uppercase tracking-wider text-muted">
              {t.workIndex.serviceFilterLegend}
            </legend>
            <div class="mt-2 flex flex-wrap gap-2" data-filter-group="services">
              <button type="button" data-filter-value="*" class="filter-chip is-active">
                {t.workIndex.all}
              </button>
              {
                pillars.map((p) => (
                  <button type="button" data-filter-value={p} class="filter-chip">
                    {pillarLabels[p]}
                  </button>
                ))
              }
            </div>
          </fieldset>

          <fieldset>
            <legend class="font-mono text-[11px] uppercase tracking-wider text-muted">
              {t.workIndex.industryFilterLegend}
            </legend>
            <div class="mt-2 flex flex-wrap gap-2" data-filter-group="industry">
              <button type="button" data-filter-value="*" class="filter-chip is-active">
                {t.workIndex.all}
              </button>
              {
                industries.map((i) => (
                  <button type="button" data-filter-value={i.toLowerCase()} class="filter-chip">
                    {i}
                  </button>
                ))
              }
            </div>
          </fieldset>
        </div>

        <p class="font-mono text-[11px] text-muted">
          <span data-result-count>{projects.length}</span> {t.workIndex.projects}
        </p>
      </div>

      <ul class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-project-grid>
        {projects.map((p) => (
          <li>
            <ProjectCard project={p} locale={locale} />
          </li>
        ))}
      </ul>

      <p class="mt-10 hidden text-center text-sm text-muted" data-empty-message>
        {t.workIndex.emptyMessage} <button type="button" data-reset class="font-medium text-brand underline">{t.workIndex.resetFilters}</button>.
      </p>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<style>
  .filter-chip {
    @apply rounded-full border border-line bg-paper px-3 py-1.5 font-mono text-[11px] font-medium text-navy transition-colors hover:border-brand;
  }
  .filter-chip.is-active {
    @apply border-navy bg-navy text-paper;
  }
  [data-project-card][data-hidden] {
    display: none;
  }
</style>

<script>
  type Group = 'services' | 'industry';
  const active: Record<Group, string> = { services: '*', industry: '*' };

  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-project-card]'));
  const grid = document.querySelector<HTMLElement>('[data-project-grid]');
  const count = document.querySelector<HTMLElement>('[data-result-count]');
  const empty = document.querySelector<HTMLElement>('[data-empty-message]');

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const services = (card.dataset.services ?? '').split(',');
      const industry = card.dataset.industry ?? '';
      const matchesService = active.services === '*' || services.includes(active.services);
      const matchesIndustry = active.industry === '*' || industry === active.industry;
      const show = matchesService && matchesIndustry;
      if (show) {
        card.removeAttribute('data-hidden');
        visible++;
      } else {
        card.setAttribute('data-hidden', '');
      }
    }
    if (count) count.textContent = String(visible);
    if (empty) empty.classList.toggle('hidden', visible > 0);
    if (grid) grid.classList.toggle('hidden', visible === 0);
  }

  document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach((group) => {
    const groupName = group.dataset.filterGroup as Group;
    group.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const btn = target.closest<HTMLButtonElement>('[data-filter-value]');
      if (!btn) return;
      const value = btn.dataset.filterValue ?? '*';
      active[groupName] = value;
      group.querySelectorAll('[data-filter-value]').forEach((el) => {
        el.classList.toggle('is-active', el === btn);
      });
      apply();
    });
  });

  document.querySelector<HTMLButtonElement>('[data-reset]')?.addEventListener('click', () => {
    active.services = '*';
    active.industry = '*';
    document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach((group) => {
      group.querySelectorAll('[data-filter-value]').forEach((el) => {
        el.classList.toggle('is-active', (el as HTMLElement).dataset.filterValue === '*');
      });
    });
    apply();
  });
</script>
