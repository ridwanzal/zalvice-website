---
import { Search, X } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import BlogHeroArt from '../../components/page-art/BlogHeroArt.astro';
import { getAllPublishedPosts } from '../../lib/cms';
import { LOCALES, getDict, isLocale, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);

const posts = await getAllPublishedPosts(locale);

// Featured post is the newest with featured=true; fall back to the newest
// post overall when no featured exists. Either way the rest of the grid
// excludes whichever post we promoted.
const featured = posts.find((p) => p.featured) ?? posts[0] ?? null;
const grid = featured ? posts.filter((p) => p.id !== featured.id) : posts;

// Distinct categories present in the rendered set — derived from data so
// adding a new post with a new category grows the filter automatically.
const categories = Array.from(new Set(posts.map((p) => p.category))).sort();
---

<BaseLayout locale={locale} title={t.blog.title} description={t.blog.description}>
  <Header slot="header" locale={locale} />

  {/* Hero */}
  <section class="bg-paper">
    <div class="container py-16 md:py-20 lg:py-24">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">{t.blog.eyebrow}</p>
          <h1 class="mt-3 max-w-3xl font-display text-h1 font-bold leading-tight">
            <span class="heading-gradient">{t.blog.headlineEmph}</span>
          </h1>
          <p class="mt-5 max-w-2xl text-lg text-ink/75 md:text-xl">{t.blog.intro}</p>
        </div>
        <div class="ml-auto w-full">
          <BlogHeroArt />
        </div>
      </div>
    </div>
  </section>

  {/* Featured */}
  {
    featured && (
      <section class="bg-mist py-12 md:py-16" aria-label={t.blog.featuredEyebrow}>
        <div class="container">
          <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.14em] text-brand">
            {t.blog.featuredEyebrow}
          </p>
          <BlogPostCard post={featured} locale={locale} variant="featured" />
        </div>
      </section>
    )
  }

  {/* Filters + grid */}
  <section class="bg-mist py-12 md:py-20">
    <div class="container">
      <div class="flex flex-col gap-6 rounded-2xl border border-line bg-paper p-5 md:flex-row md:items-center md:justify-between md:p-6">
        <div class="space-y-4 md:flex md:items-center md:gap-6 md:space-y-0">
          <fieldset>
            <legend class="font-mono text-[11px] uppercase tracking-wider text-muted">
              {t.blog.categoryLegend}
            </legend>
            <div class="mt-2 flex flex-wrap gap-2" data-category-filter>
              <button type="button" data-category-value="*" class="filter-chip is-active">
                {t.blog.allCategory}
              </button>
              {categories.map((cat) => (
                <button type="button" data-category-value={cat} class="filter-chip">
                  {cat}
                </button>
              ))}
            </div>
          </fieldset>

          <div class="md:ml-auto md:w-72">
            <label for="blog-search" class="sr-only">{t.blog.searchPlaceholder}</label>
            <div class="relative">
              <Search class="pointer-events-none absolute left-3 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-muted" aria-hidden="true" />
              <input
                id="blog-search"
                type="search"
                autocomplete="off"
                placeholder={t.blog.searchPlaceholder}
                data-blog-search
                class="w-full rounded-lg border border-line bg-paper py-2 pl-9 pr-9 font-mono text-[12px] text-ink placeholder:text-muted focus:border-brand"
              />
              <button
                type="button"
                aria-label={t.blog.searchClear}
                data-blog-search-clear
                class="absolute right-2 top-1/2 hidden h-6 w-6 -translate-y-1/2 items-center justify-center rounded text-muted hover:text-navy"
              >
                <X class="h-3.5 w-3.5" aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>

        <p class="font-mono text-[11px] text-muted">
          <span data-result-count>{grid.length}</span> {t.blog.countSuffix}
        </p>
      </div>

      <ul class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-post-grid>
        {grid.map((p) => (
          <li data-post-card data-category={p.category} data-search-blob={`${p.title} ${p.excerpt} ${p.authorName}`.toLowerCase()}>
            <BlogPostCard post={p} locale={locale} />
          </li>
        ))}
      </ul>

      <p class="mt-10 hidden text-center text-sm text-muted" data-empty-message>
        {t.blog.emptyMessage}
        <button type="button" data-reset class="ml-1 font-medium text-brand underline">
          {t.blog.resetCategory}
        </button>
      </p>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<style>
  .filter-chip {
    @apply rounded-full border border-line bg-paper px-3 py-1.5 font-mono text-[11px] font-medium text-navy transition-colors hover:border-brand;
  }
  .filter-chip.is-active {
    @apply border-navy bg-navy text-paper;
  }
  [data-post-card][hidden] { display: none; }
</style>

<script>
  /*
   * Blog index filter + search. Same shape as the /work filter:
   * inline DOM script, ~60 LOC, no framework.
   *
   * Category filter is per-chip. Search is substring against a precomputed
   * "search blob" attribute on each card (title + excerpt + author name).
   * Pagefind handles full-text search across post bodies separately when
   * its index is loaded; this client-side filter is the lightweight
   * fallback that always works.
   */
  let activeCategory = '*';
  let query = '';

  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-post-card]'));
  const grid = document.querySelector<HTMLElement>('[data-post-grid]');
  const count = document.querySelector<HTMLElement>('[data-result-count]');
  const empty = document.querySelector<HTMLElement>('[data-empty-message]');
  const searchInput = document.querySelector<HTMLInputElement>('[data-blog-search]');
  const searchClear = document.querySelector<HTMLButtonElement>('[data-blog-search-clear]');

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const cat = card.dataset.category ?? '';
      const blob = card.dataset.searchBlob ?? '';
      const matchesCat = activeCategory === '*' || cat === activeCategory;
      const matchesQuery = query.length === 0 || blob.includes(query);
      const show = matchesCat && matchesQuery;
      if (show) {
        card.removeAttribute('hidden');
        visible++;
      } else {
        card.setAttribute('hidden', '');
      }
    }
    if (count) count.textContent = String(visible);
    if (empty) empty.classList.toggle('hidden', visible > 0);
    if (grid) grid.classList.toggle('hidden', visible === 0);
    if (searchClear) searchClear.style.display = query.length > 0 ? 'inline-flex' : 'none';
  }

  document.querySelector<HTMLElement>('[data-category-filter]')?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const btn = target.closest<HTMLButtonElement>('[data-category-value]');
    if (!btn) return;
    activeCategory = btn.dataset.categoryValue ?? '*';
    document.querySelectorAll<HTMLElement>('[data-category-value]').forEach((el) => {
      el.classList.toggle('is-active', el === btn);
    });
    apply();
  });

  searchInput?.addEventListener('input', () => {
    query = (searchInput.value ?? '').trim().toLowerCase();
    apply();
  });
  searchClear?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    query = '';
    apply();
    searchInput.focus();
  });

  document.querySelector<HTMLButtonElement>('[data-reset]')?.addEventListener('click', () => {
    activeCategory = '*';
    query = '';
    if (searchInput) searchInput.value = '';
    document.querySelectorAll<HTMLElement>('[data-category-value]').forEach((el) => {
      el.classList.toggle('is-active', (el as HTMLElement).dataset.categoryValue === '*');
    });
    apply();
  });
</script>
