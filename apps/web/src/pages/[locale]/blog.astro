---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { LOCALES, getDict, isLocale, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);
---

<BaseLayout locale={locale} title={`${t.nav.blog} — Zalvice`}>
  <Header slot="header" locale={locale} />
  <section class="py-12 container">
    <h2 class="text-2xl font-semibold">{t.nav.blog}</h2>
    <p class="mt-4">{t.articles.intro}</p>
  </section>
  <Footer slot="footer" locale={locale} />
</BaseLayout>
