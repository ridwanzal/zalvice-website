---
import { ArrowRight, CalendarDays, Mail, MapPin, Send, Clock } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { LOCALES, getDict, isLocale, pathFor, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);

const projectTypes = [
  { value: 'design', label: t.contact.projectTypes.design },
  { value: 'development', label: t.contact.projectTypes.development },
  { value: 'infrastructure', label: t.contact.projectTypes.infrastructure },
  { value: 'support', label: t.contact.projectTypes.support },
  { value: 'consulting', label: t.contact.projectTypes.consulting },
  { value: 'other', label: t.contact.projectTypes.other },
];

const budgets = [
  { value: 'under_25k', label: t.contact.budgets.under_25k },
  { value: '25k_75k', label: t.contact.budgets['25k_75k'] },
  { value: '75k_200k', label: t.contact.budgets['75k_200k'] },
  { value: '200k_plus', label: t.contact.budgets['200k_plus'] },
  { value: 'not_sure', label: t.contact.budgets.not_sure },
];

const timelines = [
  { value: 'asap', label: t.contact.timelines.asap },
  { value: '1_3_months', label: t.contact.timelines['1_3_months'] },
  { value: '3_6_months', label: t.contact.timelines['3_6_months'] },
  { value: 'exploring', label: t.contact.timelines.exploring },
];
---

<BaseLayout locale={locale} title={t.contact.title} description={t.contact.description}>
  <Header slot="header" locale={locale} />

  {/* Hero */}
  <section class="bg-paper">
    <div class="container py-16 md:py-20 lg:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">{t.contact.eyebrow}</p>
      <h1 class="mt-3 max-w-3xl font-display text-h1 font-bold leading-tight">
        <span class="heading-gradient">{t.contact.headlineEmph}</span>
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/75 md:text-xl">{t.contact.intro}</p>
      <ul class="mt-8 flex flex-wrap items-center gap-3 font-mono text-[11px]">
        {t.contact.chips.map((chip, i) => (
          <li class="inline-flex items-center gap-1.5 rounded-full border border-line bg-mist px-3 py-1.5 text-navy">
            {i === 0 && <Clock class="h-3 w-3" aria-hidden="true" />}
            {chip}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-mist py-16 md:py-24">
    <div class="container grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr]">
      {/* Form */}
      <div class="rounded-2xl border border-line bg-paper p-6 shadow-[0_1px_0_rgba(10,37,64,0.04),0_24px_48px_-24px_rgba(10,37,64,0.18)] md:p-10">
        <h2 class="font-display text-2xl font-bold text-navy">{t.contact.formTitle}</h2>
        <p class="mt-2 text-sm text-ink/70">
          {t.contact.formIntro}
          <a href={pathFor(locale, '/privacy')} class="underline hover:text-brand">{t.contact.privacyPolicy}</a>.
        </p>

        <form
          method="post"
          action="/api/leads"
          class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2"
          novalidate
        >
          <div class="hidden" aria-hidden="true">
            <label>
              Website
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div class="md:col-span-2">
            <label for="name" class="block text-sm font-medium text-navy">
              {t.contact.labels.name} <span class="text-brand">*</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink placeholder:text-muted focus:border-brand"
              placeholder={t.contact.placeholders.name}
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-navy">
              {t.contact.labels.email} <span class="text-brand">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink placeholder:text-muted focus:border-brand"
              placeholder={t.contact.placeholders.email}
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-navy">{t.contact.labels.company}</label>
            <input
              id="company"
              name="company"
              type="text"
              autocomplete="organization"
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink placeholder:text-muted focus:border-brand"
              placeholder={t.contact.placeholders.company}
            />
          </div>

          <div>
            <label for="projectType" class="block text-sm font-medium text-navy">
              {t.contact.labels.projectType} <span class="text-brand">*</span>
            </label>
            <select
              id="projectType"
              name="projectType"
              required
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink focus:border-brand"
            >
              <option value="">{t.contact.placeholders.chooseOne}</option>
              {projectTypes.map((p) => <option value={p.value}>{p.label}</option>)}
            </select>
          </div>

          <div>
            <label for="budgetRange" class="block text-sm font-medium text-navy">
              {t.contact.labels.budget} <span class="text-brand">*</span>
            </label>
            <select
              id="budgetRange"
              name="budgetRange"
              required
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink focus:border-brand"
            >
              <option value="">{t.contact.placeholders.chooseOne}</option>
              {budgets.map((b) => <option value={b.value}>{b.label}</option>)}
            </select>
          </div>

          <div class="md:col-span-2">
            <label for="timeline" class="block text-sm font-medium text-navy">{t.contact.labels.timeline}</label>
            <select
              id="timeline"
              name="timeline"
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink focus:border-brand"
            >
              <option value="">{t.contact.placeholders.chooseOne}</option>
              {timelines.map((tl) => <option value={tl.value}>{tl.label}</option>)}
            </select>
          </div>

          <div class="md:col-span-2">
            <label for="message" class="block text-sm font-medium text-navy">
              {t.contact.labels.message} <span class="text-brand">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              minlength="20"
              maxlength="5000"
              rows="6"
              class="mt-1.5 w-full rounded-lg border border-line bg-paper px-4 py-2.5 text-ink placeholder:text-muted focus:border-brand"
              placeholder={t.contact.placeholders.message}
            ></textarea>
            <p class="mt-1.5 font-mono text-[11px] text-muted">{t.contact.messageHint}</p>
          </div>

          <div class="flex flex-col items-start justify-between gap-4 md:col-span-2 md:flex-row md:items-center">
            <p class="text-xs text-muted">
              {t.contact.turnstileNotice}
              <a href={pathFor(locale, '/terms')} class="underline hover:text-brand">{t.contact.terms}</a>.
            </p>
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-full bg-navy px-6 py-3 font-medium text-paper transition-colors hover:bg-brand"
            >
              {t.contact.send}
              <Send class="h-4 w-4" aria-hidden="true" />
            </button>
          </div>
        </form>
      </div>

      {/* Right rail */}
      <aside class="space-y-6">
        <div id="book" class="rounded-2xl border border-line bg-paper p-6">
          <h2 class="font-display text-lg font-semibold text-navy">{t.contact.bookTitle}</h2>
          <p class="mt-2 text-sm text-ink/70">{t.contact.bookBody}</p>
          <a
            href="https://cal.com/zalvice/discovery"
            class="mt-5 inline-flex items-center gap-2 rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:bg-navy"
          >
            <CalendarDays class="h-4 w-4" aria-hidden="true" />
            {t.contact.openCalendar}
            <ArrowRight class="h-3.5 w-3.5" aria-hidden="true" />
          </a>
        </div>

        <div class="rounded-2xl border border-line bg-paper p-6">
          <h2 class="font-display text-lg font-semibold text-navy">{t.contact.emailTitle}</h2>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a
                href="mailto:hello@zalvice.com"
                class="inline-flex items-center gap-2 text-ink hover:text-brand"
              >
                <Mail class="h-4 w-4" aria-hidden="true" />
                hello@zalvice.com
                <span class="font-mono text-[11px] text-muted">{t.contact.emailGeneral}</span>
              </a>
            </li>
            <li>
              <a
                href="mailto:sales@zalvice.com"
                class="inline-flex items-center gap-2 text-ink hover:text-brand"
              >
                <Mail class="h-4 w-4" aria-hidden="true" />
                sales@zalvice.com
                <span class="font-mono text-[11px] text-muted">{t.contact.emailSales}</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  {/* Offices */}
  <section class="bg-paper py-20 md:py-28" aria-labelledby="offices-heading">
    <div class="container">
      <header class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">{t.contact.officesEyebrow}</p>
        <h2 id="offices-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
          <span class="heading-gradient">{t.contact.officesHeadlineEmph}</span>
        </h2>
      </header>
      <ul class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          t.contact.offices.map((o) => (
            <li class="relative rounded-2xl border border-line bg-paper p-6 transition-colors hover:border-navy">
              <div class="flex items-center justify-between">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-mist text-brand">
                  <MapPin class="h-5 w-5" aria-hidden="true" />
                </span>
                {o.primary && (
                  <span class="rounded-full bg-mist px-2.5 py-1 font-mono text-[11px] font-medium text-brand">
                    {t.contact.hq}
                  </span>
                )}
              </div>
              <h3 class="mt-5 font-display text-lg font-semibold text-navy">
                {o.city}
                <span class="ml-1 text-muted">· {o.country}</span>
              </h3>
              <p class="mt-2 whitespace-pre-line text-sm leading-relaxed text-ink/70">
                {o.address}
              </p>
              <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-muted">
                {o.timezone}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
</BaseLayout>
