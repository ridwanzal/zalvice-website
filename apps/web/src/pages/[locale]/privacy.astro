---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LegalPage from '../../components/LegalPage.astro';
import { LOCALES, getDict, isLocale, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);
---

<BaseLayout locale={locale} title={t.privacy.title} description={t.privacy.description}>
  <Header slot="header" locale={locale} />
  <LegalPage
    eyebrow={t.privacy.eyebrow}
    headlineEmph={t.privacy.headlineEmph}
    intro={t.privacy.intro}
    lastUpdatedLabel={t.privacy.lastUpdatedLabel}
    lastUpdated={t.privacy.lastUpdated}
    draftNotice={t.privacy.draftNotice}
    sections={t.privacy.sections}
  />
  <Footer slot="footer" locale={locale} />
</BaseLayout>
