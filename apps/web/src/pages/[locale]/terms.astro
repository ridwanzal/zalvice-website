---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LegalPage from '../../components/LegalPage.astro';
import { LOCALES, getDict, isLocale, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!isLocale(localeParam)) return Astro.redirect('/en');
const locale: Locale = localeParam;
const t = getDict(locale);
---

<BaseLayout locale={locale} title={t.terms.title} description={t.terms.description}>
  <Header slot="header" locale={locale} />
  <LegalPage
    eyebrow={t.terms.eyebrow}
    headlineEmph={t.terms.headlineEmph}
    intro={t.terms.intro}
    lastUpdatedLabel={t.terms.lastUpdatedLabel}
    lastUpdated={t.terms.lastUpdated}
    draftNotice={t.terms.draftNotice}
    sections={t.terms.sections}
  />
  <Footer slot="footer" locale={locale} />
</BaseLayout>
