---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Masthead from '../components/Masthead.astro';
import LogoStrip from '../components/LogoStrip.astro';
import ServicesOverview from '../components/ServicesOverview.astro';
import { getStats, getServices, getClients } from '../lib/cms';

// Build-time data fetch. With CMS_MODE=fixture (default) this reads from
// fixtures and never touches the network — see skills.md §2.
const [stats, services, clients] = await Promise.all([
  getStats(),
  getServices(),
  getClients(),
]);
---

<BaseLayout
  title="Zalvice — engineers of the systems companies rely on"
  description="From blueprint to production — design, development, infrastructure, and ongoing support. One integrated team that has helped 100+ companies transform how they operate."
>
  <Header slot="header" />

  <Masthead stats={stats} />
  <LogoStrip clients={clients} />
  <ServicesOverview services={services} />

  <Footer slot="footer" />
</BaseLayout>
