---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="From blueprint to production — we engineer the systems companies rely on.">
  <Header slot="header" />
  <section class="py-12 container">
    <h1 class="text-3xl md:text-5xl font-bold">From blueprint to production — we engineer the systems companies rely on.</h1>
    <p class="mt-4 text-lg">Design, development, infrastructure, and ongoing support — one integrated team.</p>
    <div class="mt-6 flex gap-4">
      <a href="/contact" class="px-4 py-2 bg-brand text-white rounded">Start a project</a>
      <a href="/work" class="px-4 py-2 border rounded">See our work</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
