---
import { ArrowLeft } from 'lucide-astro';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PostForm from '../../../components/admin/PostForm.astro';
import { requireAdmin } from '../../../lib/admin';

export const prerender = false;

const auth = await requireAdmin(Astro);
if (!auth.user) return auth.redirect;
const user = auth.user;
---

<AdminLayout title="New post" user={user}>
  <header class="mb-8">
    <a href="/admin/posts" class="inline-flex items-center gap-2 font-mono text-xs text-muted hover:text-brand">
      <ArrowLeft class="h-3.5 w-3.5" aria-hidden="true" />
      Back to posts
    </a>
    <h1 class="mt-3 font-display text-3xl font-bold text-navy">New post</h1>
    <p class="mt-1 text-sm text-ink/70">Fill in the fields below. Status starts as draft.</p>
  </header>

  <PostForm action="/api/admin/posts" submitLabel="Create post" />
</AdminLayout>
