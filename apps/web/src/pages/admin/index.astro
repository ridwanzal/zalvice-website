---
import { FileText, Briefcase, MessageSquareQuote, ArrowRight } from 'lucide-astro';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin, apiGet } from '../../lib/admin';

export const prerender = false;

const auth = await requireAdmin(Astro);
if (!auth.user) return auth.redirect;
const user = auth.user;

type PostRow = {
  id: number;
  slug: string;
  locale: 'en' | 'id';
  title: string;
  status: 'draft' | 'scheduled' | 'published' | 'archived';
  publishedAt: string | null;
  updatedAt: string;
  featured: boolean;
};

type ProjectRow = {
  id: number;
  slug: string;
  locale: 'en' | 'id';
  clientName: string;
  title: string;
  status: 'draft' | 'published' | 'archived';
  year: number;
  featured: boolean;
  updatedAt: string;
};

type TestimonialRow = {
  id: number;
  status: 'draft' | 'published' | 'archived';
  featured: boolean;
};

const [postsResp, projectsResp, testimonialsResp] = await Promise.all([
  apiGet<{ posts: PostRow[] }>(Astro, '/api/admin/posts').catch(() => ({ posts: [] })),
  apiGet<{ projects: ProjectRow[] }>(Astro, '/api/admin/projects').catch(() => ({ projects: [] })),
  apiGet<{ testimonials: TestimonialRow[] }>(Astro, '/api/admin/testimonials').catch(() => ({
    testimonials: [],
  })),
]);

const posts = postsResp.posts;
const projects = projectsResp.projects;
const testimonials = testimonialsResp.testimonials;

const postsByStatus = {
  draft: posts.filter((p) => p.status === 'draft').length,
  scheduled: posts.filter((p) => p.status === 'scheduled').length,
  published: posts.filter((p) => p.status === 'published').length,
  archived: posts.filter((p) => p.status === 'archived').length,
};

const projectsByStatus = {
  draft: projects.filter((p) => p.status === 'draft').length,
  published: projects.filter((p) => p.status === 'published').length,
  archived: projects.filter((p) => p.status === 'archived').length,
};

const testimonialsPublished = testimonials.filter((t) => t.status === 'published').length;
const testimonialsFeatured = testimonials.filter(
  (t) => t.status === 'published' && t.featured,
).length;

const recentPosts = posts.slice(0, 5);
const recentProjects = projects.slice(0, 5);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<AdminLayout title="Dashboard" user={user}>
  <header class="mb-8">
    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-brand">Dashboard</p>
    <h1 class="mt-1 font-display text-3xl font-bold text-navy">Welcome back, {user.name.split(' ')[0]}.</h1>
  </header>

  {/* Counts */}
  <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <a
      href="/admin/posts"
      class="group rounded-2xl border border-line bg-paper p-5 transition-colors hover:border-navy"
    >
      <div class="flex items-center justify-between">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-mist text-brand">
          <FileText class="h-5 w-5" aria-hidden="true" />
        </span>
        <ArrowRight class="h-4 w-4 text-muted transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
      </div>
      <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-muted">Blog posts</p>
      <p class="mt-1 font-display text-3xl font-bold text-navy">{posts.length}</p>
      <p class="mt-2 font-mono text-[11px] text-muted">
        {postsByStatus.published} published · {postsByStatus.draft} draft
      </p>
    </a>

    <a
      href="/admin/projects"
      class="group rounded-2xl border border-line bg-paper p-5 transition-colors hover:border-navy"
    >
      <div class="flex items-center justify-between">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-mist text-brand">
          <Briefcase class="h-5 w-5" aria-hidden="true" />
        </span>
        <ArrowRight class="h-4 w-4 text-muted transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
      </div>
      <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-muted">Projects</p>
      <p class="mt-1 font-display text-3xl font-bold text-navy">{projects.length}</p>
      <p class="mt-2 font-mono text-[11px] text-muted">
        {projectsByStatus.published} published · {projectsByStatus.draft} draft
      </p>
    </a>

    <a
      href="/admin/testimonials"
      class="group rounded-2xl border border-line bg-paper p-5 transition-colors hover:border-navy"
    >
      <div class="flex items-center justify-between">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-mist text-brand">
          <MessageSquareQuote class="h-5 w-5" aria-hidden="true" />
        </span>
        <ArrowRight class="h-4 w-4 text-muted transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
      </div>
      <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-muted">Reviews</p>
      <p class="mt-1 font-display text-3xl font-bold text-navy">{testimonialsPublished}</p>
      <p class="mt-2 font-mono text-[11px] text-muted">
        published · {testimonialsFeatured} featured
      </p>
    </a>

    <div class="rounded-2xl border border-line bg-paper p-5">
      <p class="font-mono text-[11px] uppercase tracking-wider text-muted">Archived</p>
      <p class="mt-3 font-display text-3xl font-bold text-navy">
        {postsByStatus.archived + projectsByStatus.archived}
      </p>
      <p class="mt-2 font-mono text-[11px] text-muted">soft-deleted records</p>
    </div>
  </section>

  {/* Recent activity */}
  <section class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-2xl border border-line bg-paper">
      <header class="flex items-center justify-between border-b border-line px-5 py-4">
        <h2 class="font-display text-lg font-semibold text-navy">Recent posts</h2>
        <a href="/admin/posts" class="text-sm font-medium text-brand hover:underline">All</a>
      </header>
      <ul class="divide-y divide-line">
        {recentPosts.length === 0 ? (
          <li class="px-5 py-8 text-center text-sm text-muted">No posts yet — create your first.</li>
        ) : (
          recentPosts.map((p) => (
            <li class="px-5 py-3">
              <a href={`/admin/posts/${p.id}/edit`} class="group flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <p class="truncate font-display text-sm font-semibold text-navy group-hover:text-brand">
                    {p.title}
                  </p>
                  <p class="mt-0.5 font-mono text-[11px] text-muted">
                    {p.locale.toUpperCase()} · {fmt.format(new Date(p.updatedAt))}
                  </p>
                </div>
                <span
                  class:list={[
                    'rounded-full px-2 py-0.5 font-mono text-[10px] font-medium',
                    p.status === 'published'
                      ? 'bg-success/10 text-success'
                      : p.status === 'draft'
                        ? 'bg-mist text-muted'
                        : 'bg-mist text-navy',
                  ]}
                >
                  {p.status}
                </span>
              </a>
            </li>
          ))
        )}
      </ul>
    </div>

    <div class="rounded-2xl border border-line bg-paper">
      <header class="flex items-center justify-between border-b border-line px-5 py-4">
        <h2 class="font-display text-lg font-semibold text-navy">Recent projects</h2>
        <a href="/admin/projects" class="text-sm font-medium text-brand hover:underline">All</a>
      </header>
      <ul class="divide-y divide-line">
        {recentProjects.length === 0 ? (
          <li class="px-5 py-8 text-center text-sm text-muted">No projects yet — create your first.</li>
        ) : (
          recentProjects.map((p) => (
            <li class="px-5 py-3">
              <a href={`/admin/projects/${p.id}/edit`} class="group flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <p class="truncate font-display text-sm font-semibold text-navy group-hover:text-brand">
                    {p.title}
                  </p>
                  <p class="mt-0.5 font-mono text-[11px] text-muted">
                    {p.clientName} · {p.locale.toUpperCase()} · {p.year}
                  </p>
                </div>
                <span
                  class:list={[
                    'rounded-full px-2 py-0.5 font-mono text-[10px] font-medium',
                    p.status === 'published'
                      ? 'bg-success/10 text-success'
                      : p.status === 'draft'
                        ? 'bg-mist text-muted'
                        : 'bg-mist text-navy',
                  ]}
                >
                  {p.status}
                </span>
              </a>
            </li>
          ))
        )}
      </ul>
    </div>
  </section>
</AdminLayout>
