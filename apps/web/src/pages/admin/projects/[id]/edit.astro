---
import { ArrowLeft, ExternalLink } from 'lucide-astro';
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import ProjectForm from '../../../../components/admin/ProjectForm.astro';
import { requireAdmin, apiGet } from '../../../../lib/admin';

export const prerender = false;

const auth = await requireAdmin(Astro);
if (!auth.user) return auth.redirect;
const user = auth.user;

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect('/admin/projects', 302);

type ProjectFull = {
  id: number;
  slug: string;
  locale: 'en' | 'id';
  clientName: string;
  title: string;
  summary: string;
  bodyMd: string;
  heroImageUrl: string | null;
  heroImageAlt: string | null;
  year: number;
  industry: string;
  services: string[];
  techStack: string[];
  outcomes: { label: string; value: string; unit?: string }[];
  teamSize: number;
  durationMonths: number;
  featured: boolean;
  featuredOrder: number;
  status: 'draft' | 'published' | 'archived';
  publishedAt: string | null;
  seoTitle: string | null;
  seoDescription: string | null;
};

let project: ProjectFull;
try {
  const resp = await apiGet<{ project: ProjectFull }>(Astro, `/api/admin/projects/${id}`);
  project = resp.project;
} catch {
  return Astro.redirect('/admin/projects', 302);
}

const publicHref = `/${project.locale}/work/${project.slug}`;
---

<AdminLayout title={`Edit · ${project.title}`} user={user}>
  <header class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <a href="/admin/projects" class="inline-flex items-center gap-2 font-mono text-xs text-muted hover:text-brand">
        <ArrowLeft class="h-3.5 w-3.5" aria-hidden="true" />
        Back to projects
      </a>
      <h1 class="mt-3 font-display text-3xl font-bold text-navy">Edit project</h1>
      <p class="mt-1 font-mono text-[11px] text-muted">
        ID {project.id} · locale {project.locale.toUpperCase()} · status {project.status}
      </p>
    </div>
    {project.status === 'published' && (
      <a
        href={publicHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-line bg-paper px-4 py-2 text-sm text-ink hover:border-brand hover:text-brand"
      >
        View live
        <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
      </a>
    )}
  </header>

  <ProjectForm action={`/api/admin/projects/${id}`} values={project} submitLabel="Save changes" />
</AdminLayout>
