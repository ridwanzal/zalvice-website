---
import { ArrowRight, Award, Globe2, ShieldCheck, Sparkles } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TeamMemberCard from '../components/TeamMemberCard.astro';
import { getTeamMembers, getStats, findStat } from '../lib/cms';

const [team, stats] = await Promise.all([getTeamMembers(), getStats()]);

const teams: { slug: 'design' | 'eng' | 'infra' | 'ops'; label: string }[] = [
  { slug: 'eng', label: 'Engineering' },
  { slug: 'design', label: 'Design' },
  { slug: 'infra', label: 'Infrastructure' },
  { slug: 'ops', label: 'Operations' },
];

const yearsInOperation = findStat(stats, 'years_in_operation');
const companiesServed = findStat(stats, 'companies_served');

const values = [
  {
    icon: ShieldCheck,
    label: 'Reliability over novelty',
    body: 'We pick boring tools that age well. Your business depends on the system long after the launch.',
  },
  {
    icon: Sparkles,
    label: 'Engineering rigor',
    body: 'Specs, tests, observability, runbooks. The unglamorous work that prevents incidents at 3am.',
  },
  {
    icon: Award,
    label: 'Senior bench',
    body: 'Every engineer brings 5+ years from the industries we work in. No bait-and-switch staffing.',
  },
  {
    icon: Globe2,
    label: 'Remote-first, time-zone-aware',
    body: 'Async by default. Synchronous when it matters. We follow the work, not the calendar.',
  },
];
---

<BaseLayout
  title="About — Zalvice"
  description="A senior, remote-first engineering team building the systems companies rely on. Eight pillars of work — design, engineering, infrastructure, operations — under one roof."
>
  <Header slot="header" />

  {/* Hero */}
  <section class="relative overflow-hidden bg-paper">
    <div aria-hidden="true" class="absolute inset-0 opacity-[0.04] about-grid"></div>
    <div class="container relative py-20 md:py-28 lg:py-32">
      <div class="grid grid-cols-1 items-end gap-12 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">About Zalvice</p>
          <h1 class="mt-3 max-w-3xl font-display text-h1 font-bold leading-tight">
            <span class="heading-gradient">A small senior team</span>
            <span class="text-navy"> that builds the systems your business runs on.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-ink/75 md:text-xl">
            We're an integrated design, engineering, and operations team. No outsourced delivery,
            no offshore handoff, no junior bait-and-switch. Everyone on the engineering bench has
            shipped production for at least five years.
          </p>
        </div>
        <dl class="grid grid-cols-2 gap-6 border-l border-line pl-8">
          <div>
            <dt class="font-mono text-[11px] uppercase tracking-wider text-muted">Founded</dt>
            <dd class="mt-1 font-display text-3xl font-bold text-navy">
              {yearsInOperation ? `${new Date().getFullYear() - yearsInOperation.value}` : '2018'}
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[11px] uppercase tracking-wider text-muted">Clients</dt>
            <dd class="mt-1 font-display text-3xl font-bold text-navy">
              {companiesServed ? companiesServed.value : 100}
              <span class="text-brand">{companiesServed?.suffix ?? '+'}</span>
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[11px] uppercase tracking-wider text-muted">Team</dt>
            <dd class="mt-1 font-display text-3xl font-bold text-navy">{team.length}</dd>
          </div>
          <div>
            <dt class="font-mono text-[11px] uppercase tracking-wider text-muted">Avg. tenure</dt>
            <dd class="mt-1 font-display text-3xl font-bold text-navy">
              {Math.round(team.reduce((a, m) => a + m.yearsExperience, 0) / team.length)}
              <span class="text-brand">yrs</span>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  {/* Story */}
  <section class="bg-mist py-20 md:py-24">
    <div class="container grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">Our story</p>
        <h2 class="mt-3 font-display text-h2 font-bold leading-tight">
          <span class="heading-gradient">From an engineering practice, not a sales pipeline.</span>
        </h2>
      </div>
      <div class="space-y-5 text-lg text-ink/80">
        <p>
          Zalvice started because too many companies were getting "delivery teams" that couldn't
          actually deliver — long pitches, junior staff, projects that left them worse off than
          when they started.
        </p>
        <p>
          We built a different shape: a small senior team that owns the work end to end. Design,
          engineering, infrastructure, and operations sit in the same room (mostly virtual,
          sometimes physical) and ship together.
        </p>
        <p>
          Today we partner with companies on the systems they cannot afford to get wrong — billing,
          clinical records, logistics, AI-backed knowledge bases. We stay on after launch because
          the system is now part of how the business runs.
        </p>
      </div>
    </div>
  </section>

  {/* Values */}
  <section class="bg-paper py-20 md:py-28">
    <div class="container">
      <header class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">How we work</p>
        <h2 class="mt-3 font-display text-h2 font-bold leading-tight">
          <span class="heading-gradient">Four principles, not a values poster.</span>
        </h2>
      </header>
      <ul class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          values.map(({ icon: Icon, label, body }) => (
            <li class="flex gap-5 rounded-2xl border border-line bg-paper p-6">
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-mist text-brand">
                <Icon class="h-5 w-5" aria-hidden="true" />
              </span>
              <div>
                <h3 class="font-display text-lg font-semibold text-navy">{label}</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink/70">{body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Team */}
  <section class="bg-mist py-20 md:py-28 lg:py-32" aria-labelledby="team-heading">
    <div class="container">
      <header class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">The team</p>
          <h2 id="team-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
            <span class="heading-gradient">Senior bench, every seat.</span>
          </h2>
          <p class="mt-4 text-lg text-ink/75">
            Every engineer on the bench has 5+ years of production experience in the industries
            we work in. No junior bait-and-switch, no offshore handoff.
          </p>
        </div>
        <ul class="flex flex-wrap gap-2" aria-label="Filter by team">
          {
            teams.map((t) => {
              const count = team.filter((m) => m.team === t.slug).length;
              if (count === 0) return null;
              return (
                <li>
                  <a
                    href={`#team-${t.slug}`}
                    class="inline-flex items-center gap-1.5 rounded-full border border-line bg-paper px-3 py-1.5 font-mono text-[11px] font-medium text-navy hover:border-brand hover:text-brand"
                  >
                    {t.label}
                    <span class="text-muted">{count}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </header>

      {
        teams.map((t) => {
          const members = team.filter((m) => m.team === t.slug);
          if (members.length === 0) return null;
          return (
            <div id={`team-${t.slug}`} class="mt-14 scroll-mt-24">
              <h3 class="font-display text-xl font-semibold text-navy">{t.label}</h3>
              <ul class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {members.map((m) => (
                  <li>
                    <TeamMemberCard member={m} />
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>
  </section>

  {/* CTA */}
  <section class="bg-paper py-20 md:py-24">
    <div class="container">
      <div class="flex flex-col items-start gap-6 rounded-2xl border border-line bg-mist p-8 md:flex-row md:items-center md:justify-between md:p-12">
        <div class="max-w-xl">
          <h2 class="font-display text-2xl font-bold text-navy md:text-3xl">
            Want to work with this team?
          </h2>
          <p class="mt-2 text-ink/75">
            Discovery calls are with an engineer or designer — not a salesperson. We'll tell you
            quickly if we're the right fit.
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-full bg-navy px-6 py-3 font-medium text-paper transition-colors hover:bg-brand"
        >
          Start a project
          <ArrowRight class="h-4 w-4" aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-grid {
    background-image:
      linear-gradient(to right, theme('colors.navy') 1px, transparent 1px),
      linear-gradient(to bottom, theme('colors.navy') 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>
