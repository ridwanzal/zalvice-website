---
import { ArrowRight, Code, LifeBuoy, Palette, Server } from 'lucide-astro';
import type { CmsService } from '../lib/cms';

interface Props {
  services: CmsService[];
}

const { services } = Astro.props;

// Map icon-name strings (stored in the CMS as Lucide kebab-case) to components.
// New icons go in this map — we intentionally don't dynamic-import the whole
// Lucide package, which would defeat per-icon tree-shaking.
const iconMap = {
  palette: Palette,
  code: Code,
  server: Server,
  'life-buoy': LifeBuoy,
} as const;

type IconName = keyof typeof iconMap;

function getIcon(name: string) {
  return (iconMap as Record<string, (typeof iconMap)[IconName] | undefined>)[name] ?? Palette;
}
---

<section class="bg-paper py-16 md:py-24 lg:py-32">
  <div class="container">
    <header class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-wider text-brand">What we do</p>
      <h2 class="mt-3 font-bold text-navy text-h2">Four pillars, one integrated team</h2>
      <p class="mt-4 text-lg text-ink/80">
        We deliver design, development, infrastructure, and support together — not as four separate
        quotes. One team, one shared standard, end to end.
      </p>
    </header>

    <ul class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => {
          const Icon = getIcon(service.icon);
          return (
            <li>
              <a
                href={`/services#${service.slug}`}
                class="group flex h-full flex-col rounded-xl border border-line bg-paper p-6 transition-all hover:border-brand hover:shadow-sm"
                data-analytics="cta_click"
                data-analytics-location="homepage_services"
                data-analytics-label={service.slug}
              >
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-mist text-brand">
                  <Icon class="h-5 w-5" aria-hidden="true" />
                </span>
                <h3 class="mt-5 text-lg font-semibold text-navy">{service.name}</h3>
                <p class="mt-2 text-sm text-ink/70">{service.description}</p>
                <ul class="mt-4 flex flex-wrap gap-2">
                  {service.capabilities.slice(0, 3).map((cap) => (
                    <li class="rounded-full bg-mist px-2.5 py-1 text-xs font-medium text-muted">
                      {cap}
                    </li>
                  ))}
                </ul>
                <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-brand">
                  Learn more
                  <ArrowRight
                    class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"
                    aria-hidden="true"
                  />
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
