---
import { ArrowRight, BookOpen, Settings } from 'lucide-astro';
import type { CmsPostSummary } from '../lib/cms';
import { getDict, pathFor, type Locale } from '../lib/i18n';

interface Props {
  posts: CmsPostSummary[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = getDict(locale);

const fmt = new Intl.DateTimeFormat(locale === 'id' ? 'id-ID' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

{
  posts.length > 0 && (
    <section class="bg-mist py-20 md:py-28 lg:py-32" aria-labelledby="articles-heading">
      <div class="container">
        <header class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-xl">
            <p class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.14em] text-brand">
              <BookOpen class="h-3.5 w-3.5" aria-hidden="true" />
              {t.articles.eyebrow}
            </p>
            <h2 id="articles-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
              <span class="heading-gradient">{t.articles.headlineEmph}</span>
            </h2>
            <p class="mt-3 text-lg text-ink/75">{t.articles.intro}</p>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-line bg-paper px-3 py-1.5 font-mono text-[11px] text-muted">
              <Settings class="h-3 w-3" aria-hidden="true" />
              {t.articles.managedIn}
            </span>
            <a
              href={pathFor(locale, '/blog')}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-navy hover:text-brand"
            >
              {t.articles.allArticles}
              <ArrowRight class="h-3.5 w-3.5" aria-hidden="true" />
            </a>
          </div>
        </header>

        <ul class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <li>
              <a
                href={pathFor(locale, `/blog/${post.slug}`)}
                class="group flex h-full flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:border-navy hover:shadow-[0_12px_36px_-16px_rgba(10,37,64,0.18)]"
              >
                <div class="relative aspect-[16/10] overflow-hidden bg-mist">
                  {post.coverUrl ? (
                    <img
                      src={post.coverUrl}
                      alt={post.coverAlt ?? ''}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    />
                  ) : (
                    <div class="absolute inset-0 cover-placeholder" aria-hidden="true" />
                  )}
                  <span class="absolute left-4 top-4 rounded-full bg-paper/90 px-2.5 py-1 font-mono text-[11px] font-medium text-navy backdrop-blur">
                    {post.category}
                  </span>
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="font-display text-lg font-semibold leading-snug text-navy group-hover:text-brand">
                    {post.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink/70 line-clamp-2">
                    {post.excerpt}
                  </p>
                  <footer class="mt-auto flex items-center justify-between pt-5 font-mono text-[11px] text-muted">
                    <span>{post.authorName}</span>
                    <span>
                      {fmt.format(new Date(post.publishedAt))} · {post.readingMinutes} {t.articles.readTimeUnit}
                    </span>
                  </footer>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}

<style>
  .cover-placeholder {
    background-image:
      radial-gradient(circle at 30% 20%, theme('colors.brand') 0%, transparent 45%),
      linear-gradient(135deg, theme('colors.navy') 0%, theme('colors.brand') 100%);
    opacity: 0.9;
  }
</style>
