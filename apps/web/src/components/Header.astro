---
import MobileNav from './MobileNav.astro';
import LocaleSwitcher from './LocaleSwitcher.astro';
import {
  getDict,
  getLocaleFromUrl,
  pathFor,
  type Locale,
} from '../lib/i18n';

interface Props {
  /** Active locale — usually `Astro.params.locale`. Falls back to URL detection. */
  locale?: Locale | undefined;
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const t = getDict(locale);

const nav = [
  { href: pathFor(locale, '/services'), label: t.nav.services },
  { href: pathFor(locale, '/work'), label: t.nav.work },
  { href: pathFor(locale, '/blog'), label: t.nav.blog },
  { href: pathFor(locale, '/about'), label: t.nav.about },
  { href: pathFor(locale, '/contact'), label: t.nav.contact },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-paper/90 backdrop-blur border-b border-line">
  <div class="container flex items-center justify-between py-4">
    <a
      href={pathFor(locale, '/')}
      class="inline-flex items-center gap-3"
      aria-label={t.nav.home}
    >
      <img
        src="/logos/logos.svg"
        alt="Zalvice"
        width="120"
        height="40"
        class="h-10 w-auto"
      />
      <span class="hidden lg:inline-block border-l border-line pl-3 font-mono text-[11px] uppercase tracking-[0.12em] text-muted">
        {t.nav.tagline}
      </span>
    </a>
    <nav aria-label={t.nav.primaryLabel} class="flex items-center gap-3">
      <ul class="hidden md:flex items-center gap-6 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'transition-colors hover:text-brand',
                  currentPath === item.href || currentPath.startsWith(item.href + '/')
                    ? 'text-brand'
                    : 'text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={pathFor(locale, '/contact')}
            class="inline-flex items-center rounded-full bg-brand px-4 py-2 text-paper hover:bg-navy transition-colors"
          >
            {t.nav.startProject}
          </a>
        </li>
        <li>
          <LocaleSwitcher locale={locale} />
        </li>
      </ul>
    </nav>

    <MobileNav items={nav} currentPath={currentPath} locale={locale} />
  </div>
</header>
