---
import MobileNav from './MobileNav.astro';

const nav = [
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-paper/90 backdrop-blur border-b border-line">
  <div class="container flex items-center justify-between py-4">
    <a href="/" class="inline-flex items-center" aria-label="Zalvice home">
      <img
        src="/logos/logos.svg"
        alt="Zalvice"
        width="120"
        height="40"
        class="h-[1.875rem] w-auto"
      />
    </a>
    <nav aria-label="Primary">
      <ul class="hidden md:flex items-center gap-6 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'transition-colors hover:text-brand',
                  currentPath.startsWith(item.href) ? 'text-brand' : 'text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/contact"
            class="inline-flex items-center rounded-full bg-brand px-4 py-2 text-paper hover:bg-navy transition-colors"
          >
            Start a project
          </a>
        </li>
      </ul>
    </nav>

    <MobileNav items={nav} currentPath={currentPath} />
  </div>
</header>
