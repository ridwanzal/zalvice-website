---
/*
 * /about hero art — team constellation. Eight dots representing team
 * members scattered in a balanced asymmetric layout. Connecting lines
 * fade in and out in pairs, never all visible at once, so the
 * composition reads as a living network rather than a static org chart.
 *
 * The eight positions match the eight seed team members; rebalance
 * coordinates if the team grid grows.
 */
---

<div class="about-art" aria-hidden="true">
  <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
    {/* Soft background sweep — a single radial gradient to anchor the eye. */}
    <defs>
      <radialGradient id="about-glow" cx="50%" cy="40%" r="55%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.08" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
    </defs>
    <rect x="0" y="0" width="320" height="320" fill="url(#about-glow)" class="glow" />

    {/*
      Constellation edges — six lines that fade in/out on overlapping
      schedules. Each line connects two of the dots below. Stroke
      animation is opacity-only (compositor-friendly).
    */}
    <g class="links" fill="none" stroke-linecap="round">
      <line x1="62"  y1="80"  x2="160" y2="56"  class="link link-1" />
      <line x1="160" y1="56"  x2="252" y2="98"  class="link link-2" />
      <line x1="252" y1="98"  x2="220" y2="200" class="link link-3" />
      <line x1="220" y1="200" x2="120" y2="220" class="link link-4" />
      <line x1="120" y1="220" x2="62"  y2="80"  class="link link-5" />
      <line x1="160" y1="160" x2="252" y2="98"  class="link link-6" />
      <line x1="160" y1="160" x2="120" y2="220" class="link link-7" />
      <line x1="160" y1="160" x2="62"  y2="160" class="link link-8" />
      <line x1="160" y1="160" x2="160" y2="56"  class="link link-9" />
    </g>

    {/* Dots — 8 team members. Position chosen by eye for balanced negative space. */}
    <g class="dots">
      <circle cx="62"  cy="80"  r="6" class="dot dot-1" />
      <circle cx="160" cy="56"  r="6" class="dot dot-2" />
      <circle cx="252" cy="98"  r="6" class="dot dot-3" />
      <circle cx="62"  cy="160" r="5" class="dot dot-4" />
      <circle cx="160" cy="160" r="8" class="dot dot-5 dot--centre" />
      <circle cx="252" cy="190" r="5" class="dot dot-6" />
      <circle cx="120" cy="220" r="6" class="dot dot-7" />
      <circle cx="220" cy="200" r="6" class="dot dot-8" />
    </g>
  </svg>
</div>

<style>
  .about-art {
    position: relative;
    width: 100%;
    max-width: 26rem;
    aspect-ratio: 1 / 1;
    color: theme('colors.navy');
  }
  .about-art svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .glow {
    color: theme('colors.brand');
    animation: glow-breathe 8s ease-in-out infinite;
  }
  @keyframes glow-breathe {
    0%, 100% { opacity: 0.8; }
    50%      { opacity: 1; }
  }

  /* ─── Links: fade in/out on staggered loops ─────────────────────────── */
  .link {
    stroke: theme('colors.navy');
    stroke-width: 1;
    opacity: 0;
    animation: link-pulse 7s ease-in-out infinite;
  }
  .link-1 { animation-delay: 0.0s; }
  .link-2 { animation-delay: 0.8s; }
  .link-3 { animation-delay: 1.6s; }
  .link-4 { animation-delay: 2.4s; }
  .link-5 { animation-delay: 3.2s; }
  .link-6 { animation-delay: 0.4s; }
  .link-7 { animation-delay: 1.2s; }
  .link-8 { animation-delay: 2.0s; }
  .link-9 { animation-delay: 2.8s; }
  @keyframes link-pulse {
    0%   { opacity: 0; }
    25%  { opacity: 0.35; }
    50%  { opacity: 0.35; }
    75%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* ─── Dots: gentle individual breathing ─────────────────────────────── */
  .dot {
    fill: theme('colors.navy');
    transform-origin: center;
    transform-box: fill-box;
    animation: dot-breathe 5s ease-in-out infinite;
  }
  .dot-1 { animation-delay: 0.0s; }
  .dot-2 { animation-delay: 0.6s; }
  .dot-3 { animation-delay: 1.2s; }
  .dot-4 { animation-delay: 1.8s; }
  .dot-5 { animation-delay: 2.4s; }
  .dot-6 { animation-delay: 3.0s; }
  .dot-7 { animation-delay: 3.6s; }
  .dot-8 { animation-delay: 4.2s; }
  @keyframes dot-breathe {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.15); }
  }
  .dot--centre {
    fill: theme('colors.brand');
    /* The centre dot anchors the composition — keep it stable. */
    animation: none;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .glow, .link, .dot { animation: none !important; }
    .link { opacity: 0.35; }
    .dot { opacity: 1; transform: scale(1); }
  }
</style>
