---
import type { CmsClient } from '../lib/cms';

interface Props {
  clients: CmsClient[];
}

const { clients } = Astro.props;

// Split into two rows so each scrolls independently in opposite directions.
const mid = Math.ceil(clients.length / 2);
const rowA = clients.slice(0, mid);
const rowB = clients.slice(mid);

// Each row content is duplicated once so the translateX(-50%) animation
// produces a seamless loop. The second copy is aria-hidden so SR users
// hear each client exactly once.
---

{
  clients.length > 0 && (
    <section
      class="border-y border-line bg-mist py-10 md:py-12"
      aria-label="Trusted by these companies"
    >
      <div class="marquee-mask space-y-6 overflow-hidden">
        <div class="marquee" data-direction="left">
          <ul class="marquee-track">
            {rowA.map((c) => (
              <li class="marquee-item">
                <img
                  src={c.logoUrl ?? ''}
                  alt={c.logoAlt ?? ''}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="48"
                  class="max-h-10 w-auto object-contain opacity-70 grayscale transition-opacity hover:opacity-100"
                />
              </li>
            ))}
          </ul>
          <ul class="marquee-track" aria-hidden="true">
            {rowA.map((c) => (
              <li class="marquee-item">
                <img
                  src={c.logoUrl ?? ''}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="48"
                  class="max-h-10 w-auto object-contain opacity-70 grayscale"
                />
              </li>
            ))}
          </ul>
        </div>

        <div class="marquee" data-direction="right">
          <ul class="marquee-track">
            {rowB.map((c) => (
              <li class="marquee-item">
                <img
                  src={c.logoUrl ?? ''}
                  alt={c.logoAlt ?? ''}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="48"
                  class="max-h-10 w-auto object-contain opacity-70 grayscale transition-opacity hover:opacity-100"
                />
              </li>
            ))}
          </ul>
          <ul class="marquee-track" aria-hidden="true">
            {rowB.map((c) => (
              <li class="marquee-item">
                <img
                  src={c.logoUrl ?? ''}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="48"
                  class="max-h-10 w-auto object-contain opacity-70 grayscale"
                />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )
}

<style>
  .marquee-mask {
    /* Fade out at both edges so logos appear to enter and exit gracefully. */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
  }

  .marquee {
    display: flex;
    width: max-content;
    /* Each .marquee-track is 50% of the parent's width (they're flex items
       sized by their content), so translating by -50% advances exactly one
       track and the duplicate snaps into place — seamless loop. */
    animation: marquee-left 40s linear infinite;
  }

  .marquee[data-direction='right'] {
    animation-name: marquee-right;
  }

  .marquee:hover {
    animation-play-state: paused;
  }

  .marquee-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 3rem; /* matches between-tracks spacing via padding-right on items */
    padding-right: 3rem;
    list-style: none;
    margin: 0;
  }

  .marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      animation: none;
    }
  }
</style>
