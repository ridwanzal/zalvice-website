---
import type { CmsClient } from '../lib/cms';

interface Props {
  clients: CmsClient[];
}

const { clients } = Astro.props;

const mid = Math.ceil(clients.length / 2);
const rowA = clients.slice(0, mid);
const rowB = clients.slice(mid);

const LOGO_BOX_W = 176; // px — width of every logo cell. Forces visual parity.
const LOGO_BOX_H = 56; // px — height of every logo cell.
---

{
  clients.length > 0 && (
    <section
      class="border-y border-line bg-mist py-12 md:py-16"
      aria-label="Trusted by these companies"
    >
      <div class="marquee-mask space-y-8 overflow-hidden">
        <div class="marquee" data-direction="left">
          <ul class="marquee-track">
            {rowA.map((c) => (
              <li
                class="marquee-item"
                style={`width:${LOGO_BOX_W}px;height:${LOGO_BOX_H}px`}
              >
                <img
                  src={c.logoUrl ?? ''}
                  alt={c.logoAlt ?? ''}
                  loading="lazy"
                  decoding="async"
                  class="max-h-full max-w-full object-contain opacity-60 grayscale transition-opacity hover:opacity-100"
                />
              </li>
            ))}
          </ul>
          <ul class="marquee-track" aria-hidden="true">
            {rowA.map((c) => (
              <li
                class="marquee-item"
                style={`width:${LOGO_BOX_W}px;height:${LOGO_BOX_H}px`}
              >
                <img
                  src={c.logoUrl ?? ''}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="max-h-full max-w-full object-contain opacity-60 grayscale"
                />
              </li>
            ))}
          </ul>
        </div>

        <div class="marquee" data-direction="right">
          <ul class="marquee-track">
            {rowB.map((c) => (
              <li
                class="marquee-item"
                style={`width:${LOGO_BOX_W}px;height:${LOGO_BOX_H}px`}
              >
                <img
                  src={c.logoUrl ?? ''}
                  alt={c.logoAlt ?? ''}
                  loading="lazy"
                  decoding="async"
                  class="max-h-full max-w-full object-contain opacity-60 grayscale transition-opacity hover:opacity-100"
                />
              </li>
            ))}
          </ul>
          <ul class="marquee-track" aria-hidden="true">
            {rowB.map((c) => (
              <li
                class="marquee-item"
                style={`width:${LOGO_BOX_W}px;height:${LOGO_BOX_H}px`}
              >
                <img
                  src={c.logoUrl ?? ''}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="max-h-full max-w-full object-contain opacity-60 grayscale"
                />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )
}

<style>
  .marquee-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
  }

  .marquee {
    display: flex;
    width: max-content;
    animation: marquee-left 50s linear infinite;
  }

  .marquee[data-direction='right'] {
    animation-name: marquee-right;
  }

  .marquee:hover {
    animation-play-state: paused;
  }

  .marquee-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 4.5rem; /* between logos in the same track */
    padding-right: 4.5rem; /* matches gap so the duplicate track flows seamlessly */
    list-style: none;
    margin: 0;
  }

  .marquee-item {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      animation: none;
    }
  }
</style>
