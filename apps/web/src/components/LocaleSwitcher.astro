---
import { LOCALES, LOCALE_LABELS, LOCALE_NATIVE_NAMES, getDict, switchLocaleHref, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  /** Compact = inline pill group (header). Stacked = vertical list (mobile nav). */
  variant?: 'compact' | 'stacked' | undefined;
}

const { locale, variant = 'compact' } = Astro.props;
const t = getDict(locale);
const currentPath = Astro.url.pathname;
---

{
  variant === 'compact' ? (
    <div
      class="inline-flex items-center rounded-full border border-line bg-paper p-0.5"
      role="group"
      aria-label={t.meta.siteSwitchLabel}
    >
      {LOCALES.map((l) => {
        const isActive = l === locale;
        return (
          <a
            href={switchLocaleHref(currentPath, l)}
            hreflang={l}
            aria-current={isActive ? 'true' : undefined}
            class:list={[
              'rounded-full px-2.5 py-1 font-mono text-[11px] font-medium uppercase tracking-wider transition-colors',
              isActive ? 'bg-navy text-paper' : 'text-muted hover:text-navy',
            ]}
          >
            {LOCALE_LABELS[l]}
          </a>
        );
      })}
    </div>
  ) : (
    <div role="group" aria-label={t.meta.siteSwitchLabel} class="grid grid-cols-2 gap-2">
      {LOCALES.map((l) => {
        const isActive = l === locale;
        return (
          <a
            href={switchLocaleHref(currentPath, l)}
            hreflang={l}
            aria-current={isActive ? 'true' : undefined}
            data-mobile-nav-link
            class:list={[
              'flex items-center justify-between rounded-xl border px-4 py-3 transition-colors',
              isActive
                ? 'border-navy bg-navy text-paper'
                : 'border-line bg-paper text-ink hover:border-brand hover:text-brand',
            ]}
          >
            <span class="font-display text-sm font-semibold">{LOCALE_NATIVE_NAMES[l]}</span>
            <span class="font-mono text-[11px] uppercase tracking-wider opacity-70">
              {LOCALE_LABELS[l]}
            </span>
          </a>
        );
      })}
    </div>
  )
}
