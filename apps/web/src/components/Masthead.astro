---
import { ArrowRight } from 'lucide-astro';
import type { CmsStat } from '../lib/cms';
import { findStat } from '../lib/cms';
import MastheadArt from './MastheadArt.astro';
import { getDict, format, pathFor, type Locale } from '../lib/i18n';

interface Props {
  stats: CmsStat[];
  locale: Locale;
}

const { stats, locale } = Astro.props;
const t = getDict(locale);

const companiesServed = findStat(stats, 'companies_served');
const trustedByLine = companiesServed
  ? format(t.masthead.eyebrustedBy, {
      value: companiesServed.value,
      suffix: companiesServed.suffix,
    })
  : t.masthead.eyebrustedByFallback;

// First variant ships server-rendered for LCP; the rotation script swaps
// the headline content on a 10s interval. Variants serialize as JSON for
// the inline script to consume — keeps the component fully static-friendly.
const variants = t.masthead.variants;
const initial = variants[0]!;
---

<section class="relative overflow-hidden bg-paper">
  <div aria-hidden="true" class="absolute inset-0 opacity-[0.04] blueprint-grid"></div>

  <div class="container relative py-16 md:py-24 lg:py-28">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.2fr_1fr] lg:gap-16">
      {/* Left column — pitch + CTAs */}
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-line bg-mist px-3 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-navy"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand" aria-hidden="true"></span>
          {trustedByLine}
        </span>

        <h1
          class="mt-6 max-w-2xl font-display text-h1 font-bold leading-tight"
          data-masthead-headline
        >
          <span class="heading-gradient" data-masthead-emphasis>{initial.emphasis}</span><span
            class="text-navy"
            data-masthead-rest>{initial.rest}</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg text-ink/75 md:text-xl">
          {t.masthead.subhead}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={pathFor(locale, '/contact')}
            class="inline-flex items-center gap-2 rounded-full bg-navy px-6 py-3 font-medium text-paper transition-colors hover:bg-brand"
            data-analytics="cta_click"
            data-analytics-location="homepage_hero"
            data-analytics-label="Start a project"
          >
            {t.nav.startProject}
            <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href={pathFor(locale, '/work')}
            class="inline-flex items-center gap-2 rounded-full border border-line bg-paper px-6 py-3 font-medium text-ink transition-colors hover:border-brand hover:text-brand"
            data-analytics="cta_click"
            data-analytics-location="homepage_hero"
            data-analytics-label="See our work"
          >
            {t.masthead.seeWork}
          </a>
        </div>

        <dl class="mt-10 grid max-w-md grid-cols-3 gap-6 border-t border-line pt-6">
          {
            stats.slice(0, 3).map((s) => (
              <div>
                <dt class="font-mono text-[11px] uppercase tracking-wider text-muted">
                  {s.label}
                </dt>
                <dd class="mt-1 font-display text-2xl font-bold text-navy">
                  {s.value.toLocaleString()}
                  <span class="text-brand">{s.suffix}</span>
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      {/* Right column — pure-CSS animated composition */}
      <div class="lg:pl-8">
        <MastheadArt locale={locale} />
      </div>
    </div>
  </div>

  {/* Headline variants for the rotation script — serialized as JSON. */}
  <script
    is:inline
    type="application/json"
    data-masthead-variants
    set:html={JSON.stringify(variants)}
  />
</section>

<style>
  .blueprint-grid {
    background-image:
      linear-gradient(to right, theme('colors.navy') 1px, transparent 1px),
      linear-gradient(to bottom, theme('colors.navy') 1px, transparent 1px);
    background-size: 32px 32px;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 14%,
      black 86%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 14%,
      black 86%,
      transparent 100%
    );
  }

  /* Crossfade the headline spans during rotation. */
  [data-masthead-emphasis],
  [data-masthead-rest] {
    transition: opacity 280ms ease-out;
  }
  [data-masthead-headline][data-rotating] [data-masthead-emphasis],
  [data-masthead-headline][data-rotating] [data-masthead-rest] {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-masthead-emphasis],
    [data-masthead-rest] {
      transition: none;
    }
  }
</style>

<script>
  /*
   * Masthead headline rotator. Reads variants from the inline JSON tag,
   * cycles every 10s with a short crossfade. Honors prefers-reduced-motion
   * by leaving the first variant in place forever.
   */
  type Variant = { emphasis: string; rest: string };

  const headline = document.querySelector<HTMLElement>('[data-masthead-headline]');
  const emphasis = headline?.querySelector<HTMLElement>('[data-masthead-emphasis]');
  const rest = headline?.querySelector<HTMLElement>('[data-masthead-rest]');
  const data = document.querySelector<HTMLScriptElement>('[data-masthead-variants]');

  if (headline && emphasis && rest && data) {
    let variants: Variant[] = [];
    try {
      variants = JSON.parse(data.textContent ?? '[]') as Variant[];
    } catch {
      variants = [];
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (variants.length > 1 && !reducedMotion.matches) {
      let i = 0;
      window.setInterval(() => {
        i = (i + 1) % variants.length;
        const next = variants[i]!;
        // Fade out, swap text, fade back in.
        headline.setAttribute('data-rotating', '');
        window.setTimeout(() => {
          emphasis.textContent = next.emphasis;
          rest.textContent = next.rest;
          headline.removeAttribute('data-rotating');
        }, 300);
      }, 10_000);
    }
  }
</script>
