---
import { ArrowRight } from 'lucide-astro';
import type { CmsStat } from '../lib/cms';
import { findStat } from '../lib/cms';

interface Props {
  stats: CmsStat[];
}

const { stats } = Astro.props;

// PRD §5.1 H1: "100+ companies" line reads from stats — never hardcoded.
const companiesServed = findStat(stats, 'companies_served');
const trustedByLine = companiesServed
  ? `Trusted by ${companiesServed.value}${companiesServed.suffix} companies.`
  : 'Trusted by companies worldwide.';
---

<section class="relative overflow-hidden bg-paper">
  {/* Subtle blueprint grid — decorative, hidden from AT. */}
  <div aria-hidden="true" class="absolute inset-0 opacity-[0.04] blueprint-grid"></div>

  <div class="container relative py-16 md:py-24 lg:py-32">
    <h1 class="max-w-4xl font-bold text-navy text-h1">
      From blueprint to production — we engineer the systems companies rely on.
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-ink/80">
      Design, development, infrastructure, and ongoing support — one integrated team that has helped
      transform how companies operate.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full bg-brand px-6 py-3 text-paper font-medium hover:bg-navy transition-colors"
        data-analytics="cta_click"
        data-analytics-location="homepage_hero"
        data-analytics-label="Start a project"
      >
        Start a project
        <ArrowRight class="h-4 w-4" aria-hidden="true" />
      </a>
      <a
        href="/work"
        class="inline-flex items-center gap-2 rounded-full border border-line bg-paper px-6 py-3 text-ink font-medium hover:border-brand hover:text-brand transition-colors"
        data-analytics="cta_click"
        data-analytics-location="homepage_hero"
        data-analytics-label="See our work"
      >
        See our work
      </a>
    </div>

    <p class="mt-12 text-sm font-medium uppercase tracking-wider text-muted">{trustedByLine}</p>
  </div>
</section>

<style>
  .blueprint-grid {
    background-image:
      linear-gradient(to right, theme('colors.navy') 1px, transparent 1px),
      linear-gradient(to bottom, theme('colors.navy') 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>
