---
import { ArrowRight, Github, Linkedin, Twitter, Mail, MapPin } from 'lucide-astro';

const year = new Date().getFullYear();

const serviceLinks = [
  { href: '/services#design', label: 'Design' },
  { href: '/services#development', label: 'Development' },
  { href: '/services#infrastructure', label: 'Infrastructure' },
  { href: '/services#support', label: 'Support' },
  { href: '/services#consulting', label: 'Consulting' },
];

const companyLinks = [
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const social = [
  { href: 'https://www.linkedin.com/company/zalvice', label: 'LinkedIn', Icon: Linkedin },
  { href: 'https://github.com/zalvice', label: 'GitHub', Icon: Github },
  { href: 'https://x.com/zalvice', label: 'X', Icon: Twitter },
];
---

<footer class="bg-navy text-paper" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>

  <div class="container py-16 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      {/* Col 1 — Brand */}
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center" aria-label="Zalvice home">
          <img src="/logos/logos.png" alt="Zalvice" width="86" height="25" class="h-7 w-auto invert" />
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-paper/70">
          From blueprint to production — we engineer the systems companies rely on. Design,
          development, infrastructure, support, and consulting under one roof.
        </p>
        <ul class="mt-6 flex items-center gap-3">
          {
            social.map(({ href, label, Icon }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={label}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-paper/20 text-paper/80 transition-colors hover:border-brand hover:bg-brand hover:text-paper"
                >
                  <Icon class="h-4 w-4" aria-hidden="true" />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Col 2 — Services */}
      <nav class="md:col-span-2" aria-label="Services">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-paper/60">Services</p>
        <ul class="mt-4 space-y-3 text-sm">
          {
            serviceLinks.map(({ href, label }) => (
              <li>
                <a class="text-paper/80 transition-colors hover:text-brand" href={href}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Col 3 — Company */}
      <nav class="md:col-span-2" aria-label="Company">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-paper/60">Company</p>
        <ul class="mt-4 space-y-3 text-sm">
          {
            companyLinks.map(({ href, label }) => (
              <li>
                <a class="text-paper/80 transition-colors hover:text-brand" href={href}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Col 4 — Get in touch */}
      <div class="md:col-span-4">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-paper/60">Get in touch</p>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              class="inline-flex items-center gap-2 text-paper/80 transition-colors hover:text-brand"
              href="mailto:hello@zalvice.com"
            >
              <Mail class="h-4 w-4" aria-hidden="true" />
              hello@zalvice.com
            </a>
          </li>
          <li class="inline-flex items-start gap-2 text-paper/80">
            <MapPin class="mt-0.5 h-4 w-4 shrink-0" aria-hidden="true" />
            <span>Jakarta · Remote-first</span>
          </li>
        </ul>
        <a
          href="/contact"
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:bg-paper hover:text-navy"
        >
          Start a project
          <ArrowRight class="h-3.5 w-3.5" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div
      class="container flex flex-col gap-3 py-6 text-xs text-paper/60 md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} Zalvice. All rights reserved.</p>
      <ul class="flex flex-wrap items-center gap-4 font-mono">
        <li><a class="hover:text-paper" href="/privacy">Privacy</a></li>
        <li><a class="hover:text-paper" href="/terms">Terms</a></li>
        <li><a class="hover:text-paper" href="/sitemap-index.xml">Sitemap</a></li>
        <li><a class="hover:text-paper" href="/rss.xml">RSS</a></li>
      </ul>
    </div>
  </div>
</footer>
