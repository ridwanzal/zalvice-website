---
import type { CmsStat } from '../lib/cms';

interface Props {
  stats: CmsStat[];
}

const { stats } = Astro.props;
---

{
  stats.length > 0 && (
    <section
      class="relative overflow-hidden bg-navy py-16 text-paper md:py-20"
      aria-labelledby="stats-heading"
    >
      <div aria-hidden="true" class="absolute inset-0 opacity-[0.08] stats-grid"></div>
      <div class="container relative">
        <header class="flex flex-col items-start gap-3 md:flex-row md:items-end md:justify-between">
          <div class="max-w-xl">
            <p class="font-mono text-xs uppercase tracking-[0.14em] text-paper/60">By the numbers</p>
            <h2 id="stats-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
              Proof, in production.
            </h2>
          </div>
          <p class="max-w-sm text-sm text-paper/70">
            Stats are pulled live from the back office — never out of date, never approximate.
          </p>
        </header>

        <dl class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-10">
          {stats.map((s) => (
            <div class="border-l-2 border-brand pl-4 md:pl-6">
              <dt class="font-mono text-[11px] uppercase tracking-wider text-paper/60">
                {s.label}
              </dt>
              <dd class="mt-2 font-display text-4xl font-bold leading-none md:text-5xl">
                {s.value.toLocaleString()}
                <span class="text-brand">{s.suffix}</span>
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )
}

<style>
  .stats-grid {
    background-image:
      linear-gradient(to right, theme('colors.paper') 1px, transparent 1px),
      linear-gradient(to bottom, theme('colors.paper') 1px, transparent 1px);
    background-size: 48px 48px;
  }
</style>
