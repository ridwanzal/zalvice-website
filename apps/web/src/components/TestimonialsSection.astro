---
import { ArrowUpRight, Quote } from 'lucide-astro';
import type { CmsTestimonial } from '../lib/cms';
import { getDict, pathFor, type Locale } from '../lib/i18n';

interface Props {
  testimonials: CmsTestimonial[];
  locale: Locale;
  /** Compact = 3-card grid for the homepage. Full = larger list for /about. */
  variant?: 'compact' | 'full' | undefined;
}

const { testimonials, locale, variant = 'compact' } = Astro.props;
const t = getDict(locale);

const surfaceClass =
  variant === 'compact'
    ? 'bg-mist py-20 md:py-28 lg:py-32'
    : 'bg-paper py-20 md:py-24';

function initials(name: string): string {
  return name
    .split(' ')
    .map((p) => p.charAt(0))
    .slice(0, 2)
    .join('')
    .toUpperCase();
}
---

{
  testimonials.length > 0 && (
    <section class={surfaceClass} aria-labelledby="testimonials-heading">
      <div class="container">
        <header class="max-w-2xl">
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">
            {variant === 'full' ? t.testimonials.aboutEyebrow : t.testimonials.eyebrow}
          </p>
          <h2 id="testimonials-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
            <span class="heading-gradient">
              {variant === 'full' ? t.testimonials.aboutHeadlineEmph : t.testimonials.headlineEmph}
            </span>
          </h2>
          {variant === 'compact' && (
            <p class="mt-4 text-lg text-ink/75">{t.testimonials.intro}</p>
          )}
        </header>

        <ul
          class:list={[
            'mt-12 grid gap-6',
            variant === 'compact' ? 'md:grid-cols-3' : 'md:grid-cols-2',
          ]}
        >
          {testimonials.map((tm) => (
            <li class="flex flex-col rounded-2xl border border-line bg-paper p-6 md:p-8">
              <Quote class="h-6 w-6 text-brand/40" aria-hidden="true" />

              <blockquote class="mt-4 flex-1 font-display text-lg leading-snug text-navy md:text-xl">
                <p>"{tm.quote}"</p>
              </blockquote>

              <footer class="mt-6 flex items-center gap-4 border-t border-line pt-5">
                {tm.authorPhotoUrl ? (
                  <img
                    src={tm.authorPhotoUrl}
                    alt={tm.authorPhotoAlt ?? tm.authorName}
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                    class="h-12 w-12 shrink-0 rounded-full object-cover"
                  />
                ) : (
                  <span
                    aria-hidden="true"
                    class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-navy font-display text-sm font-bold text-paper"
                  >
                    {initials(tm.authorName)}
                  </span>
                )}
                <div class="min-w-0 flex-1">
                  <p class="font-display text-sm font-semibold text-navy">{tm.authorName}</p>
                  <p class="font-mono text-[11px] text-muted">
                    {tm.authorRole} · {tm.authorCompany}
                  </p>
                </div>
              </footer>

              {tm.project && (
                <a
                  href={pathFor(locale, `/work/${tm.project.slug}`)}
                  class="group mt-4 inline-flex items-center gap-1.5 self-start font-mono text-[11px] uppercase tracking-wider text-brand hover:underline"
                >
                  {t.testimonials.readCase}
                  <ArrowUpRight
                    class="h-3 w-3 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                    aria-hidden="true"
                  />
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
