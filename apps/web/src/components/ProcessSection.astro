---
import { Compass, PenTool, Hammer, Activity } from 'lucide-astro';

const steps = [
  {
    icon: Compass,
    label: 'Discover',
    body: 'We map the system end-to-end before writing a line of code — users, constraints, infra, success metrics.',
    duration: '1–2 weeks',
  },
  {
    icon: PenTool,
    label: 'Design',
    body: 'Information architecture, interaction patterns, and a working design system that engineering can ship from.',
    duration: '2–4 weeks',
  },
  {
    icon: Hammer,
    label: 'Build',
    body: 'Tight feedback loops with the people who will own the system. CI from day one, no big-bang releases.',
    duration: '6–16 weeks',
  },
  {
    icon: Activity,
    label: 'Operate',
    body: 'Once it ships, we stay on the wire — monitoring, on-call, capacity, incident response.',
    duration: 'Ongoing',
  },
];
---

<section class="bg-paper py-20 md:py-28 lg:py-32" aria-labelledby="process-heading">
  <div class="container">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand">How we work</p>
      <h2 id="process-heading" class="mt-3 font-display text-h2 font-bold leading-tight">
        <span class="heading-gradient">Discover. Design. Build. Operate.</span>
      </h2>
      <p class="mt-4 text-lg text-ink/75">
        A single integrated team carries the work from kickoff to live operations — no handoffs,
        no rework between vendors.
      </p>
    </header>

    <ol class="relative mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {/* Connecting line for desktop */}
      <div
        aria-hidden="true"
        class="absolute left-6 right-6 top-7 hidden h-px bg-line lg:block"
      ></div>
      {
        steps.map((step, i) => (
          <li class="relative rounded-2xl border border-line bg-paper p-6">
            <div class="flex items-center justify-between">
              <span class="relative z-10 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy text-paper">
                <step.icon class="h-5 w-5" aria-hidden="true" />
              </span>
              <span class="font-mono text-[11px] uppercase tracking-wider text-muted">
                Step 0{i + 1}
              </span>
            </div>
            <h3 class="mt-5 font-display text-lg font-semibold text-navy">{step.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/70">{step.body}</p>
            <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-brand">
              {step.duration}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
