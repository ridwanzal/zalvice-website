---
import '../styles/globals.css';
import { LayoutDashboard, FileText, Briefcase, LogOut } from 'lucide-astro';

/*
 * Admin shell. Two-column on lg+ (sidebar + main), single column with a
 * top bar on smaller screens. No backend-driven nav state — `currentPath`
 * comes from Astro.url and drives the active styling.
 */

interface Props {
  title: string;
  user: { name: string; email: string; role: 'admin' | 'editor' };
}

const { title, user } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/admin', label: 'Dashboard', icon: LayoutDashboard },
  { href: '/admin/posts', label: 'Blog posts', icon: FileText },
  { href: '/admin/projects', label: 'Projects', icon: Briefcase },
];

function isActive(href: string): boolean {
  if (href === '/admin') return currentPath === '/admin' || currentPath === '/admin/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
}

const initials = user.name
  .split(' ')
  .map((p) => p.charAt(0))
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0A2540" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · Zalvice admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-mist text-ink">
    <div class="lg:grid lg:grid-cols-[16rem_1fr]">
      {/* Sidebar */}
      <aside class="hidden lg:flex lg:flex-col lg:min-h-screen lg:border-r lg:border-line lg:bg-paper">
        <a
          href="/admin"
          class="flex items-center gap-2 border-b border-line px-6 py-5"
          aria-label="Zalvice admin"
        >
          <img src="/logos/logos.svg" alt="Zalvice" width="86" height="25" class="h-6 w-auto" />
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted">admin</span>
        </a>
        <nav class="flex-1 px-3 py-4" aria-label="Admin">
          <ul class="space-y-1">
            {
              nav.map((item) => {
                const Icon = item.icon;
                const active = isActive(item.href);
                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors',
                        active
                          ? 'bg-navy text-paper'
                          : 'text-ink hover:bg-mist hover:text-navy',
                      ]}
                    >
                      <Icon class="h-4 w-4" aria-hidden="true" />
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
        <div class="border-t border-line p-4">
          <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-navy font-display text-sm font-semibold text-paper">
              {initials}
            </span>
            <div class="min-w-0 flex-1">
              <p class="truncate font-display text-sm font-semibold text-navy">{user.name}</p>
              <p class="truncate font-mono text-[11px] text-muted">{user.role}</p>
            </div>
          </div>
          <form method="post" action="/api/auth/logout" class="mt-3">
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-line bg-paper px-3 py-2 text-sm text-ink transition-colors hover:border-brand hover:text-brand"
            >
              <LogOut class="h-3.5 w-3.5" aria-hidden="true" />
              Sign out
            </button>
          </form>
        </div>
      </aside>

      {/* Main */}
      <div class="flex min-h-screen flex-col">
        {/* Mobile top bar */}
        <header class="border-b border-line bg-paper lg:hidden">
          <div class="flex items-center justify-between px-4 py-3">
            <a href="/admin" class="inline-flex items-center gap-2" aria-label="Zalvice admin">
              <img src="/logos/logos.svg" alt="Zalvice" width="86" height="25" class="h-6 w-auto" />
              <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted">admin</span>
            </a>
            <form method="post" action="/api/auth/logout">
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 rounded-lg border border-line bg-paper px-3 py-1.5 text-xs text-ink hover:border-brand hover:text-brand"
              >
                <LogOut class="h-3.5 w-3.5" aria-hidden="true" />
                Sign out
              </button>
            </form>
          </div>
          <nav class="flex border-t border-line" aria-label="Admin">
            {
              nav.map((item) => {
                const active = isActive(item.href);
                return (
                  <a
                    href={item.href}
                    class:list={[
                      'flex-1 px-3 py-2.5 text-center text-xs font-medium',
                      active
                        ? 'border-b-2 border-navy text-navy'
                        : 'text-muted hover:text-navy',
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </nav>
        </header>

        <main class="flex-1 px-4 py-8 sm:px-6 lg:px-10 lg:py-10">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
