---
import '../styles/globals.css';
import SEO from '../components/SEO.astro';
import { getLocaleFromUrl, getDict, type Locale } from '../lib/i18n';

interface Props {
  title: string;
  description?: string | undefined;
  ogImage?: string | undefined;
  noindex?: boolean | undefined;
  /** Override URL-based detection (useful for the root /index.astro). */
  locale?: Locale | undefined;
}

const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const t = getDict(locale);

const {
  title,
  description = t.meta.defaultDescription,
  ogImage,
  noindex,
} = Astro.props;

const skipToContent = locale === 'id' ? 'Lewati ke konten' : 'Skip to content';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1E5FFF" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`Zalvice — ${locale === 'id' ? 'Blog (Bahasa Indonesia)' : 'Blog (English)'}`}
      href={`/${locale}/rss.xml`}
    />
    <SEO title={title} description={description} ogImage={ogImage} noindex={noindex} />
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand focus:text-paper focus:rounded-lg"
    >
      {skipToContent}
    </a>
    <slot name="header" />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
