# Copy to .env.local and fill in. Every variable below is required at runtime
# unless marked "optional". See PRD.md §8 "Environment variables" for the full
# taxonomy and skills.md §16 for how this file is loaded.

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Web (apps/web) ───────────────────────────────────────────────────────────
# Astro only exposes PUBLIC_* to the browser. Build-time vars are read in
# apps/web/src/lib/env.ts.
PUBLIC_SITE_URL=http://localhost:4321
API_URL=http://localhost:3000
BUILD_TOKEN=dev-build-token-change-me
CMS_MODE=fixture                       # fixture | live — use fixture before the API is wired up
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA  # Cloudflare test key
PUBLIC_PLAUSIBLE_DOMAIN=zalvice.com
PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.outbound-links.js

# ─── API (apps/api) ───────────────────────────────────────────────────────────
PORT=3000
DATABASE_URL=mysql://zalvice:zalvice@localhost:3306/zalvice
SESSION_SECRET=please-generate-a-32-char-secret-here
CSRF_SECRET=please-generate-a-32-char-secret-here

# Cloudflare Turnstile (server-side)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend (transactional email)
RESEND_API_KEY=re_changeme

# Slack lead notifications
SLACK_WEBHOOK_SALES=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zalvice-media-dev
R2_PUBLIC_BASE=https://media.zalvice.com

# Rebuild trigger (set in staging/prod, optional locally)
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_SECRET=

# Observability (optional in dev)
SENTRY_DSN=

# Upload virus scanning (optional in dev — skipped if unset)
CLAMAV_HOST=

# ─── Feature flags ────────────────────────────────────────────────────────────
ROUND_ROBIN_LEADS=false
I18N_ROUTING=false
NEW_PROJECT_DETAIL_LAYOUT=false
